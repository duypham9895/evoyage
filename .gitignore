# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local

# test screenshots
*.png

# tool configs
.playwright-mcp/
.superpowers/

# data artifacts
/data/
.gstack/

# Claude Code runtime state (keep agents/, docs/, skills/ tracked)
.claude/worktrees/
.claude/scheduled_tasks.lock

# session-local context (retros, scratchpads)
.context/

# Playwright run artifacts
/test-results/
