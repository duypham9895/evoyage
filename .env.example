# Database — Supabase Postgres (ap-southeast-1)
# DATABASE_URL uses the pooled connection (port 6543, ?pgbouncer=true) for app runtime.
# DIRECT_URL uses the direct connection (port 5432) for migrations / `prisma db push` / schema-drift check.
# See docs/RECOVERY.md if the project is being rebuilt from scratch.
DATABASE_URL=
DIRECT_URL=

# eVi LLM providers
# Primary: Xiaomi MiMo (mimo-v2-flash) — fast, cheap, OpenAI-compatible.
# Get a key at https://platform.xiaomimimo.com/#/console/api-keys
XIAOMI_MIMO_API_KEY=

# Fallback: Minimax M2.7 — used when MiMo is degraded.
# Get a key at https://platform.minimax.io
MINIMAX_API_KEY=

# Speech-to-text: Groq Whisper-large-v3 (free tier covers our usage).
# Get a key at https://console.groq.com — used by /api/transcribe.
GROQ_API_KEY=

# Mapbox — Directions + Matrix + traffic. Server-side token; do NOT expose.
# Get one at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# Mapbox — client-side basemap token. MUST be a separate, public token scoped
# to your web domain referrer (`url-restrictions` in the Mapbox token settings).
# Do NOT reuse MAPBOX_ACCESS_TOKEN here.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Rate limiting — Upstash Redis REST.
# Free tier is sufficient. The Vercel Marketplace install (`vercel integration
# add upstash/upstash-kv`) writes `KV_REST_API_URL` + `KV_REST_API_TOKEN`
# instead of these names; both forms are accepted by `Redis.fromEnv()` and by
# our own `hasRedis` guards. Set whichever pair you have.
# In production without either pair, /api/* falls back to an in-memory
# limiter (per-instance, useless across functions) and logs a [SECURITY]
# error from src/lib/rate-limit.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=    # Vercel Marketplace alternate names — pick one pair
# KV_REST_API_TOKEN=

# Cron auth — shared secret expected by /api/cron/* handlers (and by their
# external scheduler — currently a mix of Vercel crons in vercel.json plus
# GitHub Actions failsafes in .github/workflows/{aggregate-*,poll-*}.yml).
# Generate with: `openssl rand -hex 32`
CRON_SECRET=

# Feedback email (Resend) — used by POST /api/feedback to forward submissions.
# https://resend.com — RESEND_API_KEY is required to actually send.
# Without these, feedback is still persisted to the DB; only the email step is skipped.
RESEND_API_KEY=
FEEDBACK_EMAIL_FROM=
FEEDBACK_EMAIL_TO=

# Open Charge Map — used only by scripts/fetch-universal-stations.ts (manual crawl).
# Not required for normal app runtime. https://openchargemap.org/site/develop/api
OPEN_CHARGE_MAP_API_KEY=

# Admin panel (private)
# Gates /admin/* and /api/admin/* via HTTP Basic Auth (middleware).
# Username is hardcoded to "admin"; password is this value.
# Leave empty in dev to keep the admin panel completely inaccessible.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Vercel Blob (feedback image uploads)
# Required for the /api/feedback/upload endpoint. Without it, uploads
# fail with 503 and the rest of the feedback flow still works.
BLOB_READ_WRITE_TOKEN=

# PostHog analytics (optional)
# Leave empty to disable analytics entirely. Analytics also auto-disable when
# NODE_ENV !== 'production', so dev and tests never fire events.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
