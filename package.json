{
  "name": "evoyage",
  "version": "0.9.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:real": "MOCK_APIS=false npx playwright test",
    "seed": "npx tsx scripts/seed-vietnam-models.ts",
    "seed:stations": "npx tsx scripts/seed-osm-stations.ts",
    "seed:all": "npm run seed && npm run seed:stations",
    "db:push:local": "npx tsx scripts/db-push-local.ts",
    "db:generate": "npx prisma generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --quiet --no-warn-ignored"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sparticuz/chromium": "^148.0.0",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0",
    "@vercel/og": "^0.11.1",
    "html-to-image": "^1.11.13",
    "impit": "^0.14.1",
    "leaflet": "^1.9.4",
    "mapbox-gl": "^3.24.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "openai": "^6.39.1",
    "playwright-core": "^1.58.2",
    "posthog-js": "^1.376.5",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1"
  }
}
