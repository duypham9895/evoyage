generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EVVehicle {
  id String @id @default(cuid())

  // Identity
  brand     String
  model     String
  variant   String?
  modelYear Int?

  // Body & Category
  bodyType String
  segment  String?
  seats    Int
  doors    Int?

  // Battery & Range (CORE for trip planning)
  batteryCapacityKwh Float
  usableBatteryKwh   Float?
  officialRangeKm    Float
  rangeStandard      String?
  efficiencyWhPerKm  Float?

  // Charging (CORE for trip planning)
  dcMaxChargingPowerKw      Float?
  acChargingPowerKw         Float?
  chargingTimeDC_10to80_min Int?
  chargingPortType          String?

  // Performance
  powerKw            Float?
  torqueNm           Float?
  driveType          String?
  acceleration0to100 Float?
  topSpeedKmh        Float?

  // Dimensions & Weight
  lengthMm          Int?
  widthMm           Int?
  heightMm          Int?
  wheelbaseMm       Int?
  weightKg          Int?
  cargoVolumeLiters Int?

  // Availability
  availableInVietnam Boolean @default(false)
  priceVndMillions   Float?

  // Data Source
  source      String   @default("crawled")
  sourceUrl   String?
  isUserAdded Boolean  @default(false)
  lastUpdated DateTime @default(now())

  @@unique([brand, model, variant])
  @@index([brand])
  @@index([availableInVietnam])
  @@index([bodyType])
  @@index([seats])
}

model ChargingStation {
  id             String   @id @default(cuid())
  ocmId          String?  @unique
  name           String
  address        String
  province       String
  latitude       Float
  longitude      Float
  chargerTypes   String
  connectorTypes String
  portCount      Int
  maxPowerKw     Float
  stationType    String
  isVinFastOnly  Boolean  @default(false)
  operatingHours String?
  provider       String
  scrapedAt      DateTime @default(now())

  // VinFast-specific fields (from finaldivision API)
  entityId       String? // VinFast entity_id for detail API lookup
  stationCode    String? // e.g., "vfc_C.HNO0009"
  storeId        String? // e.g., "C.HNO0009"
  hotline        String? // Customer hotline
  hotlineService String? // Service hotline (hotline_xdv)
  chargingStatus String? // ACTIVE, BUSY, INACTIVE, UNAVAILABLE, OUTOFSERVICE
  parkingFee     Boolean? // Whether parking fee is required
  accessType     String? // Public, Restricted
  partyId        String? // VFC (car), VFS (scooter)
  hasLink        Boolean? // Whether station has linked detail
  categoryName   String? // e.g., "Trạm sạc ô tô điện"
  categorySlug   String? // e.g., "car_charging_station"
  markerIcon     String? // Icon URL for map display
  rawData        String? // Complete original JSON from source API

  // Crowdsourced status — denormalized from latest WORKING StationStatusReport
  lastVerifiedAt DateTime?

  @@index([latitude, longitude])
  @@index([province])
  @@index([provider])
  @@index([isVinFastOnly])
  @@index([chargingStatus])
  @@index([entityId])
  @@index([lastVerifiedAt])
}

model StationStatusReport {
  id        String   @id @default(cuid())
  stationId String
  status    String // "WORKING" | "BROKEN" | "BUSY"
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([stationId, createdAt])
  @@index([createdAt])
}

model VinFastStationDetail {
  id        String   @id @default(cuid())
  entityId  String   @unique
  storeId   String
  detail    String // JSON blob of VinFastStationDetail
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model ShortUrl {
  id          String    @id @default(cuid())
  code        String    @unique
  params      String    // URL search params string
  accessCount Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // reserved for future use

  @@index([createdAt])
}

model RouteCache {
  id              String   @id @default(cuid())
  startPlaceId    String
  endPlaceId      String
  polyline        String
  distanceMeters  Int
  durationSeconds Int
  createdAt       DateTime @default(now())

  @@unique([startPlaceId, endPlaceId])
  @@index([createdAt])
}

model Feedback {
  id               String    @id @default(cuid())
  category         String // REPORT_ISSUE, REQUEST_FEATURE, CONTACT_SUPPORT, STATION_DATA_ERROR, ROUTE_FEEDBACK, GENERAL_FEEDBACK
  description      String
  email            String?
  name             String?
  phone            String?
  stepsToReproduce String? // for REPORT_ISSUE
  useCase          String? // for REQUEST_FEATURE
  correctInfo      String? // for STATION_DATA_ERROR
  rating           Int? // 1-5 for ROUTE_FEEDBACK
  stationId        String? // for STATION_DATA_ERROR
  stationName      String? // for STATION_DATA_ERROR
  imageUrl         String? // Phase 2
  pageUrl          String?
  userAgent        String?
  viewport         String?
  routeParams      String?
  ipHash           String? // hashed IP for rate limiting
  emailSent        Boolean   @default(false)
  status           String    @default("NEW") // NEW, IN_REVIEW, RESOLVED, CLOSED
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([category])
  @@index([status])
  @@index([createdAt])
}
